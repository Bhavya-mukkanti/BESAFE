import React, { useEffect, useRef, useState } from "react";
import {
  Alert,
  Linking,
  StyleSheet,
  Text,
  TextInput,
  TouchableOpacity,
  Vibration,
} from "react-native";

import { KeyboardAwareScrollView } from "react-native-keyboard-aware-scroll-view";
import AsyncStorage from "@react-native-async-storage/async-storage";
import * as Location from "expo-location";
import * as Sharing from "expo-sharing";
import { Accelerometer } from "expo-sensors";

// SETTINGS
const SHAKE_THRESHOLD = 1.8;

export default function HomeScreen() {
  const [contacts, setContacts] = useState(["", "", ""]);
  const [destination, setDestination] = useState("");
  const [voiceOn, setVoiceOn] = useState(false);

  const contactsRef = useRef(contacts);

  useEffect(() => {
    contactsRef.current = contacts;
  }, [contacts]);

  // LOAD CONTACTS
  useEffect(() => {
    (async () => {
      const saved = await AsyncStorage.getItem("contacts");
      if (saved) setContacts(JSON.parse(saved));
    })();
  }, []);

  const saveContacts = async (data) => {
    await AsyncStorage.setItem("contacts", JSON.stringify(data));
  };

  // LOCATION
  const getLocation = async () => {
    const { status } = await Location.requestForegroundPermissionsAsync();
    if (status !== "granted") {
      Alert.alert("Permission denied");
      return null;
    }

    const loc = await Location.getCurrentPositionAsync({});
    return loc.coords;
  };

  // 🚀 SMART SOS
  const sendSOS = async () => {
    const valid = contactsRef.current.filter((c) => c.trim() !== "");

    if (valid.length === 0) {
      Alert.alert("Add contacts first");
      return;
    }

    const coords = await getLocation();
    if (!coords) return;

    const link = `https://maps.google.com/?q=${coords.latitude},${coords.longitude}`;

    const message = `🚨 HELP NEEDED!
📍 ${link}`;

    await Sharing.shareAsync(
      `data:text/plain;charset=utf-8,${encodeURIComponent(message)}`
    );

    Linking.openURL(`tel:${valid[0]}`);
  };

  // SHAKE
  useEffect(() => {
    Accelerometer.setUpdateInterval(300);

    const sub = Accelerometer.addListener(({ x, y, z }) => {
      const magnitude = Math.sqrt(x * x + y * y + z * z);

      if (magnitude > SHAKE_THRESHOLD) {
        Vibration.vibrate(300);
        sendSOS();
      }
    });

    return () => sub.remove();
  }, []);

  // 🎤 VOICE TRIGGER (SIMULATED)
  const startVoice = () => {
    setVoiceOn(true);

    Alert.alert(
      "Voice Activated",
      "Listening for 'HELP' (Demo mode)"
    );

    // simulate listening
    setTimeout(() => {
      if (voiceOn) {
        Alert.alert("Voice Detected", "HELP detected!");
        sendSOS();
      }
    }, 5000);
  };

  const stopVoice = () => {
    setVoiceOn(false);
    Alert.alert("Voice Off");
  };

  return (
    <KeyboardAwareScrollView contentContainerStyle={styles.container}>
      <Text style={styles.title}>🛡️ Safety App</Text>

      {/* CONTACTS */}
      {contacts.map((c, i) => (
        <TextInput
          key={i}
          style={styles.input}
          placeholder={`Contact ${i + 1}`}
          value={c}
          onChangeText={(t) => {
            const temp = [...contacts];
            temp[i] = t;
            setContacts(temp);
            saveContacts(temp);
          }}
        />
      ))}

      {/* SOS */}
      <TouchableOpacity style={styles.sos} onPress={sendSOS}>
        <Text style={styles.txt}>🚨 SOS</Text>
      </TouchableOpacity>

      {/* HELPLINE */}
      <TouchableOpacity
        style={styles.helpline}
        onPress={() => Linking.openURL("tel:112")}
      >
        <Text style={styles.txt}>📞 Helpline</Text>
      </TouchableOpacity>

      {/* VOICE */}
      {!voiceOn ? (
        <TouchableOpacity style={styles.voice} onPress={startVoice}>
          <Text style={styles.txt}>🎤 Start Voice Trigger</Text>
        </TouchableOpacity>
      ) : (
        <TouchableOpacity style={styles.stop} onPress={stopVoice}>
          <Text style={styles.txt}>⛔ Stop Voice</Text>
        </TouchableOpacity>
      )}

      {/* TRACKING */}
      <TextInput
        style={styles.input}
        placeholder="Enter destination"
        value={destination}
        onChangeText={setDestination}
      />

      <TouchableOpacity
        style={styles.track}
        onPress={() =>
          Linking.openURL(
            `https://www.google.com/maps/search/?api=1&query=${destination}`
          )
        }
      >
        <Text style={styles.txt}>📍 Open in Maps</Text>
      </TouchableOpacity>
    </KeyboardAwareScrollView>
  );
}

// UI
const styles = StyleSheet.create({
  container: { flexGrow: 1, padding: 20, backgroundColor: "#eef2f7" },
  title: { fontSize: 28, textAlign: "center", marginBottom: 20 },
  input: {
    backgroundColor: "#fff",
    padding: 14,
    marginVertical: 8,
    borderRadius: 12,
  },
  sos: { backgroundColor: "red", padding: 15, borderRadius: 12 },
  helpline: { backgroundColor: "orange", padding: 15, marginTop: 10, borderRadius: 12 },
  voice: { backgroundColor: "blue", padding: 15, marginTop: 10, borderRadius: 12 },
  track: { backgroundColor: "green", padding: 15, marginTop: 10, borderRadius: 12 },
  stop: { backgroundColor: "gray", padding: 15, marginTop: 10, borderRadius: 12 },
  txt: { color: "#fff", textAlign: "center" },
});
